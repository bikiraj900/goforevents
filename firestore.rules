rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is a logged-in Admin
    function isAdmin() {
      return request.auth != null;
    }

    // 1. CMS Content: Public can read, ONLY Admin can write
    match /cms_content/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // 2. Analytics: Public can increment visits, but ONLY Admin can read/delete
    match /analytics/{dateDoc} {
      allow read, delete: if isAdmin();
      allow create, update: if true; // Allows the frontend to increment the counter
    }

    // 3. Bookings: Public can create (submit form), ONLY Admin can read/update/delete
    match /bookings/{bookingId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // 4. Gallery Images: Public can read, ONLY Admin can upload/delete
    match /gallery_images/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 5. Default Fallback: Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
